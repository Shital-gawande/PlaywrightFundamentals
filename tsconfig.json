{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "exactOptionalPropertyTypes": false
  },
  "include": [
    "playwright.config.ts",
    "tests/**/*.ts"
  ]
}